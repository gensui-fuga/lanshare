# Maintainer: gensui-fuga <gensui-fuga@users.noreply.github.com>
# Contributor: gensui-fuga

pkgname=lanshare
pkgver=1.0.0
pkgrel=1
pkgdesc="Cross-Platform Local Network File Sharing - Share files across devices on your local network"
arch=('x86_64' 'aarch64')
url="https://github.com/gensui-fuga/lanshare"
license=('GPL3')
depends=('glibc' 'glib2')
makedepends=('go' 'git')
optdepends=('fyne: desktop GUI')
source=("$pkgname-$pkgver.tar.gz::https://github.com/gensui-fuga/lanshare/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$srcdir/$pkgname-$pkgver"
    
    # Build CLI version
    go build -trimpath -ldflags="-s -w" -o lanshare .
    
    # Build GUI version (requires fyne)
    if command -v go &>/dev/null && [ -f go.sum ]; then
        go build -tags gui -trimpath -ldflags="-s -w" -o lanshare-gui . 2>/dev/null || true
    fi
}

package() {
    cd "$srcdir/$pkgname-$pkgver"
    
    # Binary
    install -Dm755 lanshare "$pkgdir/usr/bin/lanshare"
    
    # GUI binary (if built)
    if [ -f lanshare-gui ]; then
        install -Dm755 lanshare-gui "$pkgdir/usr/bin/lanshare-gui"
    fi
    
    # Desktop entry
    install -Dm644 packaging/deb/usr/share/applications/lanshare.desktop "$pkgdir/usr/share/applications/lanshare.desktop"
    
    # Web UI (for reference / self-hosting)
    install -Dm644 static/index.html "$pkgdir/usr/share/lanshare/webui/index.html"
    
    # License
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE" 2>/dev/null || true
    
    # Documentation
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md" 2>/dev/null || true
}
